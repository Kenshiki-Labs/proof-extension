{
  "name": "proof-extension",
  "displayName": "Proof Extension",
  "version": "0.4.1",
  "description": "A browser-local observer panel for tracker detection, mitigation status, and source-level remediation routing.",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kenshiki-Labs/proof-extension.git"
  },
  "bugs": {
    "url": "https://github.com/Kenshiki-Labs/proof-extension/issues"
  },
  "homepage": "https://github.com/Kenshiki-Labs/proof-extension#readme",
  "type": "module",
  "scripts": {
    "dev": "plasmo dev",
    "dev:chrome": "plasmo dev --target=chrome-mv3",
    "build": "plasmo build",
    "build:chrome": "plasmo build --target=chrome-mv3",
    "build:chrome:debug": "plasmo build --target=chrome-mv3 --no-minify",
    "build:firefox": "plasmo build --target=firefox-mv2",
    "build:edge": "plasmo build --target=edge-mv3",
    "package": "plasmo package",
    "release:supabase": "node scripts/release-supabase.mjs",
    "lint": "eslint src eslint.config.js --ext .ts,.tsx,.js",
    "design:check": "node scripts/check-design-primitives.mjs",
    "vocab:analyze": "node scripts/analyze-vocabulary.mjs --write",
    "vocab:check": "node scripts/analyze-vocabulary.mjs --check",
    "typecheck": "tsc --noEmit",
    "test:surface-congruence": "vitest run src/core/report/surface-metrics.test.ts src/core/report/metrics.test.ts src/core/report/ui-callchain.test.ts src/core/report/display.test.ts src/core/report/badge.test.ts src/core/report/watchers.test.ts src/core/report/narrowing.test.ts src/core/report/vocabulary-guard.test.ts --coverage=false",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:browser": "vitest --config vitest.browser.config.ts run",
    "prebuild": "pnpm test:surface-congruence && pnpm typecheck",
    "prebuild:chrome": "pnpm test:surface-congruence && pnpm typecheck",
    "pretest:e2e": "pnpm build:chrome",
    "test:e2e": "playwright test",
    "qa": "pnpm lint && pnpm design:check && pnpm vocab:check && pnpm typecheck && pnpm test:coverage && pnpm intel:check && pnpm intel:promote:check && pnpm build:chrome",
    "qa:refresh": "node scripts/refresh-and-qa.mjs",
    "qa:full": "pnpm qa && pnpm test:browser && pnpm test:e2e && pnpm build:firefox && pnpm build:edge",
    "db:baseline": "node scripts/db-baseline.mjs",
    "intel:breadth": "node scripts/breadth-backlog.mjs",
    "intel:harvest": "node scripts/harvest-unclassified.mjs",
    "intel:normalize": "node scripts/normalize-intelligence.mjs",
    "intel:eval": "node scripts/eval-entity-resolution.mjs",
    "intel:check": "node scripts/check-intelligence-fresh.mjs",
    "intel:promote": "node scripts/promote-intelligence.mjs",
    "intel:promote:check": "node scripts/promote-intelligence.mjs --check"
  },
  "dependencies": {
    "lucide-react": "^1.23.0",
    "plasmo": "^0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "webextension-polyfill": "^0.12.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@playwright/test": "^1.61.1",
    "@types/chrome": "0.0.258",
    "@types/node": "^20.19.0",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.19.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.16",
    "prettier": "3.2.4",
    "svgo": "^3.3.3",
    "tailwindcss": "^3.4.19",
    "tldts": "^7.4.5",
    "typescript": "5.3.3",
    "typescript-eslint": "^8.23.0",
    "vitest": "4.1.9",
    "vitest-environment-web-ext": "^0.0.3"
  },
  "manifest": {
    "permissions": [
      "activeTab",
      "declarativeNetRequest",
      "declarativeNetRequestFeedback",
      "scripting",
      "storage",
      "webRequest"
    ],
    "optional_permissions": [
      "cookies"
    ],
    "host_permissions": [
      "<all_urls>"
    ],
    "content_security_policy": {
      "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https:; img-src 'self' data: https://api.mapbox.com"
    }
  }
}
